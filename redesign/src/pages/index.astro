---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';
---
<BaseLayout title="Pavel Kruhlei — Industrial Designer" bodyClass="home">
  <div class="card">
    <div class="address">
      <p>Pavel Kruhlei<br>Designer &amp; Digital Creator<br><br><br>Poznań, Poland<br><a href="mailto:kkrugley@proton.me">kkrugley@proton.me</a><br><br><br><br></p>
    </div>
    <div class="intro">
      <p>
        <a href="https://www.linkedin.com/in/krugley/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span>//</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
        <a href="https://www.behance.net/kkrugley" target="_blank" rel="noopener noreferrer">Behance</a>
      </p>
    </div>
  </div>

  <div id="clippy-container">
    <div id="clippy-tooltip">
      <p>Wanna see my gallery? <a href="/gallery/">Click on me!</a></p>
    </div>
    <div id="clippy">
      <a href="/gallery/"><img src="/assets/img/clippy.gif" alt="Clippy"></a>
    </div>
  </div>
</BaseLayout>

<script>
  const container = document.getElementById('clippy-container');
  const tooltip = document.getElementById('clippy-tooltip');
  if (container && tooltip) {
    setTimeout(() => {
      container.classList.add('visible');
      setTimeout(() => { tooltip.classList.add('visible'); }, 1000);
    }, 1500);
  }
</script>
