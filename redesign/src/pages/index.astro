---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';
---
<BaseLayout
  title="Pavel Kruhlei — Industrial Designer"
  bodyClass="home"
>
  <div class="card">
    <div class="address">
      <p>Pavel Kruhlei<br>Designer & Digital Creator<br><br><br>Poznań, Poland<br><a href="mailto:kkrugley@proton.me">kkrugley@proton.me</a><br><br><br><br></p>
    </div>
    <div class="intro">
      <center>
        <a href="https://www.linkedin.com/in/krugley/" target="_blank" rel="noopener noreferrer">LinkedIn</a>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span>//</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<a href="https://www.behance.net/kkrugley" target="_blank" rel="noopener noreferrer">Behance</a>
      </center>
    </div>
  </div>

  <div id="clippy-container">
    <div id="clippy-tooltip">
      <a href="/gallery/">Wanna see my gallery?</a>
    </div>
    <a href="/gallery/">
      <img src="/assets/img/clippy.gif" alt="Clippy" width="200" />
    </a>
  </div>
</BaseLayout>

<script>
  const clippyContainer = document.getElementById('clippy-container');
  const clippyTooltip = document.getElementById('clippy-tooltip');

  if (clippyContainer && clippyTooltip) {
    setTimeout(() => {
      clippyContainer.classList.add('visible');
      setTimeout(() => {
        clippyTooltip.classList.add('visible');
      }, 1000);
    }, 1500);
  }
</script>
