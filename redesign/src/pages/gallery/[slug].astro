---
// src/pages/gallery/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Lightbox from '../../components/Lightbox';
import ModelViewer from '../../components/ModelViewer';
import { getCollection } from 'astro:content';
import '../../styles/project.css';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => {
    const slug = p.id.replace(/\/index\.mdx?$/, '');
    return { params: { slug }, props: { entry: p } };
  });
}

const { entry } = Astro.props;
const { data } = entry;
const year = new Date().getFullYear();
---

<BaseLayout
  title={`${data.title} — Pavel Kruhlei`}
  description={data.tagline}
  ogImage={data.thumbnail}
  bodyClass="project-page"
>
  <div class="project-container">

    <header>
      <h1>{data.title}</h1>
      <nav class="project-menu">
        <a href="/gallery/">[← Back to Gallery]</a>
        &nbsp;&nbsp;
        <a href="mailto:kkrugley@proton.me">[E-mail Me]</a>
      </nav>
    </header>

    {data.gallery.length > 0 && (
      <Lightbox
        client:load
        images={data.gallery}
      />
    )}

    <hr style="border: none; border-top: 1px solid #ddd; margin: 20px 0;" />

    <div class="project-columns">

      <!-- LEFT: Links sidebar -->
      <aside class="project-sidebar">
        <h2>Links</h2>
        {data.links.length > 0 && (
          <ul>
            {data.links.map((link: { label: string; url: string }) => (
              <li>
                <a href={link.url} target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        )}

        {data.model3d && (
          <>
            <hr class="sidebar-divider" />
            <ModelViewer
              client:load
              src={data.model3d}
              iosSrc={data.model3d_ios}
            />
          </>
        )}
      </aside>

      <!-- RIGHT: Content -->
      <main class="project-content">

        {data.useTemplate ? (
          <!-- Portfolio template sections -->
          <div class="cs-template">

            <div class="cs-meta-row">
              <span class="cs-label">Case Study</span>
              <div class="cs-tags">
                {data.year && <span class="cs-tag">{data.year}</span>}
                {data.tags.map((tag: string) => <span class="cs-tag">{tag}</span>)}
              </div>
            </div>

            <h2 class="cs-title">{data.title}</h2>
            {data.tagline && <p class="cs-tagline">{data.tagline}</p>}

            <hr class="cs-div" />

            <!-- Hero image -->
            {data.hero
              ? <div class="cs-hero"><img src={data.hero} alt={`${data.title} hero`} /></div>
              : <div class="cs-ph cs-hero" />
            }

            <hr class="cs-div" />

            <!-- 01 Problem + 02 Solution -->
            <section>
              <div class="cs-two-col">
                <div>
                  <div class="cs-section-head">
                    <span class="cs-num">01</span>
                    <h3 class="cs-section-title">Problem</h3>
                  </div>
                  {data.problem ? (
                    <>
                      <p class="cs-body">{data.problem.text}</p>
                      {data.problem.image
                        ? <img src={data.problem.image} alt="Problem context" style="margin-top:14px;width:100%" />
                        : <div class="cs-ph" style="margin-top:14px;min-height:80px" />
                      }
                    </>
                  ) : <div class="cs-ph" style="min-height:80px" />}
                </div>
                <div>
                  <div class="cs-section-head">
                    <span class="cs-num">02</span>
                    <h3 class="cs-section-title">Solution</h3>
                  </div>
                  {data.solution ? (
                    <>
                      <p class="cs-body">{data.solution.text}</p>
                      {data.solution.image
                        ? <img src={data.solution.image} alt="Solution concept" style="margin-top:14px;width:100%" />
                        : <div class="cs-ph" style="margin-top:14px;min-height:80px" />
                      }
                    </>
                  ) : <div class="cs-ph" style="min-height:80px" />}
                </div>
              </div>
            </section>

            <hr class="cs-div" />

            <!-- 03 Process -->
            <section>
              <div class="cs-section-head">
                <span class="cs-num">03</span>
                <h3 class="cs-section-title">Process</h3>
              </div>
              <div class="cs-three-col">
                {(data.process ?? [null, null, null]).slice(0, 3).map((src: string | null, i: number) =>
                  src
                    ? <img src={src} alt={`Process step ${i + 1}`} style="width:100%;height:auto;border-radius:4px" />
                    : <div class="cs-ph" style="min-height:120px" />
                )}
              </div>
            </section>

            <hr class="cs-div" />

            <!-- 04 Design Details -->
            <section>
              <div class="cs-section-head">
                <span class="cs-num">04</span>
                <h3 class="cs-section-title">Design Details</h3>
              </div>
              <div class="cs-detail-grid">
                <div class="cs-body">
                  {data.details
                    ? <p>{data.details.text}</p>
                    : <p>Key design decisions and reasoning.</p>
                  }
                </div>
                {data.details?.image
                  ? <img src={data.details.image} alt="Design detail" style="width:100%;height:auto;border-radius:4px" />
                  : <div class="cs-ph" style="min-height:140px" />
                }
              </div>
            </section>

            <hr class="cs-div" />

            <!-- 05 Final Design -->
            <section>
              <div class="cs-section-head">
                <span class="cs-num">05</span>
                <h3 class="cs-section-title">Final Design</h3>
              </div>
              <div class="cs-final-grid">
                {data.final?.main
                  ? <img src={data.final.main} alt="Final design" class="cs-final-main" style="width:100%;object-fit:cover;border-radius:6px" />
                  : <div class="cs-ph cs-final-main" />
                }
                <div class="cs-final-side">
                  {data.final?.detail
                    ? <img src={data.final.detail} alt="Design detail" style="width:100%;height:auto;border-radius:4px" />
                    : <div class="cs-ph" />
                  }
                  {data.final?.context
                    ? <img src={data.final.context} alt="In context" style="width:100%;height:auto;border-radius:4px" />
                    : <div class="cs-ph" />
                  }
                </div>
              </div>
            </section>

          </div>
        ) : (
          <!-- Legacy: free-form description -->
          <div class="legacy-description">
            <h2>Description</h2>
            {data.description && (
              <div set:html={data.description.replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br />')} />
            )}
          </div>
        )}

      </main>
    </div>

  </div>

  <footer style="text-align:center;padding:16px;font-size:12px;font-family:'Times New Roman',serif;">
    <p>&copy; Pavel Kruhlei — {year}</p>
  </footer>
</BaseLayout>
