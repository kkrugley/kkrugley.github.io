---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryGrid from '../../components/GalleryGrid';
import { getCollection } from 'astro:content';
import '../../styles/gallery.css';

const allProjects = await getCollection('projects');
const projectCards = allProjects.map(p => ({
  slug: p.id.replace(/\/index\.mdx?$/, ''),
  title: p.data.title,
  thumbnail: p.data.thumbnail,
}));
const year = new Date().getFullYear();
---

<BaseLayout title="Gallery — Pavel Kruhlei" bodyClass="gallery-page">
  <h1>Pavel Kruhlei's Gallery</h1>
  <h3 class="menu">
    [&nbsp;<a href="/">Home</a>&nbsp;]&nbsp;
    [&nbsp;<a href="mailto:kkrugley@proton.me">E-mail Me</a>&nbsp;]&nbsp;
    [&nbsp;<button id="refresh-btn">Refresh</button>&nbsp;]&nbsp;
    [&nbsp;<button id="show-all-btn">Show All</button>&nbsp;]
  </h3>

  <GalleryGrid client:load projects={projectCards} initialCount={8} />

  <footer>
    <p>{year} &copy; Pavel Kruhlei &amp; respective copyright holders</p>
  </footer>
</BaseLayout>

<script>
  document.getElementById('refresh-btn')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('gallery:refresh'));
  });
  document.getElementById('show-all-btn')?.addEventListener('click', function() {
    (this as HTMLButtonElement).style.display = 'none';
    window.dispatchEvent(new CustomEvent('gallery:showAll'));
  });
</script>
