const overlay = document.getElementById('pgp-overlay') as HTMLElement | null;
const form    = document.getElementById('pgp-form') as HTMLFormElement | null;
const closeBtn = document.getElementById('pgp-close');
const submitBtn = document.getElementById('pgp-submit') as HTMLButtonElement | null;
const statusDiv = document.getElementById('pgp-status') as HTMLElement | null;

const openModal  = (e?: Event) => { e?.preventDefault(); overlay?.classList.add('open'); };
const closeModal = () => overlay?.classList.remove('open');

// Any element with data-pgp-open triggers the modal
document.querySelectorAll('[data-pgp-open]').forEach(el =>
  el.addEventListener('click', openModal)
);

closeBtn?.addEventListener('click', closeModal);
overlay?.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

form?.addEventListener('submit', async e => {
  e.preventDefault();
  if (!submitBtn || !statusDiv || !form) return;

  const name    = (form.elements.namedItem('name')    as HTMLInputElement)?.value.trim();
  const email   = (form.elements.namedItem('email')   as HTMLInputElement)?.value.trim();
  const message = (form.elements.namedItem('message') as HTMLTextAreaElement)?.value.trim();

  if (!name || !email || !message) {
    statusDiv.textContent = 'Please fill in all fields.';
    statusDiv.className = 'pgp-status error';
    statusDiv.hidden = false;
    return;
  }

  submitBtn.disabled = true;
  submitBtn.textContent = 'Encrypting…';
  statusDiv.hidden = true;

  try {
    // Lazy-load openpgp.js
    if (!(window as any).openpgp) {
      await new Promise<void>((resolve, reject) => {
        const s = document.createElement('script');
        s.src = 'https://unpkg.com/openpgp@5/dist/openpgp.min.js';
        s.onload = () => resolve();
        s.onerror = () => reject(new Error('Failed to load OpenPGP library'));
        document.head.appendChild(s);
      });
    }

    const openpgp = (window as any).openpgp;
    const fullMessage = `From: ${name}\nEmail: ${email}\nDate: ${new Date().toLocaleString('en-GB')}\n\nMessage:\n${message}`;

    const encrypted = await openpgp.encrypt({
      message: await openpgp.createMessage({ text: fullMessage }),
      encryptionKeys: await openpgp.readKey({ armoredKey: PUBLIC_KEY }),
      format: 'armored',
    });

    submitBtn.textContent = 'Sending…';

    const resp = await fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        access_key: 'd3b2562a-86bc-446f-b51a-cc567c1e6649',
        subject: 'Encrypted Message — kkrugley.github.io',
        from_name: 'Anonymous',
        from_email: 'noreply@kkrugley.github.io',
        message: encrypted,
      }),
    });

    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);

    statusDiv.textContent = '✓ Message encrypted and sent successfully.';
    statusDiv.className = 'pgp-status success';
    statusDiv.hidden = false;
    form.reset();
  } catch (err) {
    console.error(err);
    statusDiv.textContent = '✗ Error encrypting or sending. Please try again.';
    statusDiv.className = 'pgp-status error';
    statusDiv.hidden = false;
  } finally {
    submitBtn.disabled = false;
    submitBtn.textContent = 'Encrypt & Send';
  }
});
</script>
