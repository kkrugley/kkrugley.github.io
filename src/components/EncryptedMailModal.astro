---
// src/components/EncryptedMailModal.astro
---

<div id="pgp-overlay" class="pgp-overlay" role="dialog" aria-modal="true" aria-label="Send encrypted message">
  <div class="pgp-modal">
    <div class="pgp-modal-title">
      <span>Send Encrypted Message</span>
      <button id="pgp-close" aria-label="Close">×</button>
    </div>
    <form id="pgp-form" novalidate>
      <div class="pgp-field">
        <label for="pgp-name">Name</label>
        <input type="text" id="pgp-name" name="name" required autocomplete="name" />
      </div>
      <div class="pgp-field">
        <label for="pgp-email">Reply-to email</label>
        <input type="email" id="pgp-email" name="email" required autocomplete="email" />
      </div>
      <div class="pgp-field">
        <label for="pgp-message">Message</label>
        <textarea id="pgp-message" name="message" rows="6" required></textarea>
      </div>
      <div id="pgp-status" class="pgp-status" hidden></div>
      <button type="submit" class="pgp-submit" id="pgp-submit">Encrypt &amp; Send</button>
    </form>
    <p class="pgp-note">Your message will be encrypted with OpenPGP before sending. The server never sees plain text.</p>
  </div>
</div>

<style is:global>
.pgp-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 3000;
  align-items: center;
  justify-content: center;
}

.pgp-overlay.open {
  display: flex;
}

.pgp-modal {
  background: white;
  box-shadow: 0px 0px 15px 1px rgba(0, 0, 0, 0.3);
  padding: 20px 24px 16px;
  width: min(500px, 92vw);
  font-family: 'Times New Roman', serif;
  max-height: 90vh;
  overflow-y: auto;
}

.pgp-modal-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
  font-size: 1rem;
  font-weight: bold;
  border-bottom: 1px solid #ccc;
  padding-bottom: 8px;
}

#pgp-close {
  background: none;
  border: none;
  font-size: 1.5rem;
  line-height: 1;
  cursor: pointer;
  font-family: inherit;
  padding: 0;
  color: #000;
}

#pgp-close:hover { color: #FF0000; }

.pgp-field {
  margin-bottom: 10px;
}

.pgp-field label {
  display: block;
  font-size: 13px;
  font-weight: bold;
  margin-bottom: 3px;
  color: #333;
}

.pgp-field input,
.pgp-field textarea {
  width: 100%;
  font-family: 'Times New Roman', serif;
  font-size: 13px;
  border: 1px solid #ccc;
  padding: 5px 7px;
  background: #fafafa;
  box-sizing: border-box;
  color: #000;
}

.pgp-field textarea { resize: vertical; }

.pgp-field input:focus,
.pgp-field textarea:focus {
  outline: 1px solid #0000EE;
  border-color: #0000EE;
}

.pgp-status {
  margin-bottom: 10px;
  padding: 7px 10px;
  font-size: 12px;
  border: 1px solid #ccc;
}

.pgp-status.success { background: #f0fff4; border-color: #4ade80; color: #0f4c3a; }
.pgp-status.error   { background: #fff5f5; border-color: #f87171; color: #4c1d1d; }

.pgp-submit {
  font-family: 'Times New Roman', serif;
  font-size: 13px;
  background: none;
  border: 1px solid #0000EE;
  color: #0000EE;
  padding: 5px 18px;
  cursor: pointer;
  text-decoration: underline;
}

.pgp-submit:hover { text-decoration: none; }

.pgp-submit:disabled {
  color: #999;
  border-color: #999;
  cursor: default;
  text-decoration: none;
}

.pgp-note {
  margin-top: 12px;
  font-size: 11px;
  color: #888;
  font-style: italic;
  line-height: 1.4;
}
</style>

